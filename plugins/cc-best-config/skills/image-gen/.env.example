# Required: API key for the OpenAI-compatible endpoint
IMAGE_GEN_API_KEY=your-api-key-here

# Required: Base URL of the OpenAI-compatible endpoint
IMAGE_GEN_BASE_URL=https://openrouter.ai/api/v1

# Optional: Model name (default: google/gemini-3-1-flash-image-preview)
IMAGE_GEN_MODEL=google/gemini-3-1-flash-image-preview

# Optional: Default face image URL for face-based editing
# IMAGE_GEN_FACE_URL=https://example.com/face.jpg
