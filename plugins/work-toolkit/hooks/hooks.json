{
  "description": "Best-practice hooks: skill-scoped CLI agent context / hf CLI / python env (PreToolUse via Skill matcher), file protection, push + desktop notifications, and stop guard.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/skill-prerun.sh agent-task ${CLAUDE_PLUGIN_ROOT}/hooks/agent-cli-context.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/skill-prerun.sh hf-papers python3 ${CLAUDE_PLUGIN_ROOT}/skills/hf-papers/scripts/ensure_hf_cli.py"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/skill-prerun.sh data-analysis python3 ${CLAUDE_PLUGIN_ROOT}/skills/data-analysis/scripts/ensure_python_env.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/notify-push.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-guard.sh"
          }
        ]
      }
    ]
  }
}
